# ============================================================================
# .env.example – copy to .env and fill in values
# Key-based auth is DISABLED. No connection string is needed or used.
# ============================================================================

# ── Event Hub namespace (do NOT include .servicebus.windows.net) ─────────────
EH_NAMESPACE=<your-eventhubs-namespace>

# ── Topic / Event Hub names (defaults shown – only override if you rename them)
TOPIC_PASSENGERS=custcomplaints.passengers
TOPIC_FLIGHTS=custcomplaints.flights
TOPIC_CASES=custcomplaints.cases
TOPIC_COMPLAINTS=custcomplaints.complaints

# ── Tenant (REQUIRED – pins the iss claim so Event Hubs can validate the JWT) ─
AZURE_TENANT_ID=<your-entra-tenant-id>

# ── Managed identity ──────────────────────────────────────────────────────────
# User-Assigned Managed Identity client ID
# Found in: Azure Portal → Managed Identities → <your-uami> → Overview → Client ID
UAMI_CLIENT_ID=<your-uami-client-id>

# Set to "true" when running ON Azure with the UAMI assigned to the compute resource.
# Set to "false" for local dev — falls back to Azure CLI / VS Code credentials.
USE_MANAGED_IDENTITY=true
