# ============================================================================
# .env.example – copy to .env and fill in values
# Key-based auth is DISABLED. No connection string is needed or used.
# ============================================================================

# ── Event Hub namespace (do NOT include .servicebus.windows.net) ─────────────
EH_NAMESPACE=<your-eventhubs-namespace>

# ── Topic / Event Hub names (defaults shown – only override if you rename them)
TOPIC_PASSENGERS=custcomplaints.passengers
TOPIC_FLIGHTS=custcomplaints.flights
TOPIC_CASES=custcomplaints.cases
TOPIC_COMPLAINTS=custcomplaints.complaints

# ── Tenant (REQUIRED – pins the iss claim so Event Hubs can validate the JWT) ─
AZURE_TENANT_ID=<your-entra-tenant-id>

# ── Managed identity ──────────────────────────────────────────────────────────
# User-Assigned Managed Identity client ID.
# Found in: Azure Portal → Managed Identities → <your-uami> → Overview → Client ID
# Leave unset to use system-assigned managed identity or AzureCliCredential (local dev).
UAMI_CLIENT_ID=<your-uami-client-id>

# Set to "true" when running ON Azure with the UAMI assigned to the compute resource.
# Set to "false" for local dev — falls back to Azure CLI / VS Code credentials.
USE_MANAGED_IDENTITY=true

# ── Schema Registry ───────────────────────────────────────────────────────────
# Schema group that must already exist in the Event Hubs namespace.
# Create it via ARM REST API (az rest --method put) with schemaType=Json.
SCHEMA_GROUP=custcomplaints

# ── Fabric Eventstream Custom Endpoint ───────────────────────────────────────
# Namespace and topic shown in Eventstream canvas → Custom Endpoint → Entra ID Authentication tab
FABRIC_EH_NAMESPACE=<fabric-custom-endpoint-namespace-passengers>
FABRIC_TOPIC_PASSENGERS=<fabric-custom-endpoint-eventhub-name-passengers>

FABRIC_EH_NAMESPACE_FLIGHTS=<fabric-custom-endpoint-namespace-flights>
FABRIC_TOPIC_FLIGHTS=<fabric-custom-endpoint-eventhub-name-flights>

FABRIC_EH_NAMESPACE_CASES=<fabric-custom-endpoint-namespace-cases>
FABRIC_TOPIC_CASES=<fabric-custom-endpoint-eventhub-name-cases>

FABRIC_EH_NAMESPACE_COMPLAINTS=<fabric-custom-endpoint-namespace-complaints>
FABRIC_TOPIC_COMPLAINTS=<fabric-custom-endpoint-eventhub-name-complaints>

# ── Fabric Schema Registry (fabricstreams producer / avro_producer) ───────────
# Base URL of the Fabric messaging catalog endpoint.
# Found in the schema registry URL shown in Fabric Eventstream → EventSchemaSet.
# Format: https://<hostname>.messagingcatalog.azure.net
FABRIC_SCHEMA_REGISTRY_ENDPOINT=<your-fabric-schema-registry-endpoint>

# GUID of the EventSchemaSet item.
# Found in: Fabric workspace URL when the schema set is open.
FABRIC_SCHEMA_SET_ID=<your-fabric-schema-set-guid>
