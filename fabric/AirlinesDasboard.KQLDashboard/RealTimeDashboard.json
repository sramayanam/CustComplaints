  "queries": [
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "9f9ecc39-7e11-4128-beaf-d1a24293afff"
      },
      "text": "casesnew\n| where case_status !in (\"Resolved\", \"Closed\")\n| summarize open_cases=count() by passenger_id\n| where open_cases > 1\n| join kind=inner (passengersnew | project passenger_id, first_name, last_name, frequent_flyer_tier) on passenger_id\n| project first_name, last_name, frequent_flyer_tier, open_cases\n| order by open_cases desc\n",
      "id": "084143dd-215d-4034-97c3-20c56a05530e",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "9f9ecc39-7e11-4128-beaf-d1a24293afff"
      },
      "text": "complaintsnew\n| summarize count() by category, severity\n| order by count_ desc",
      "id": "71e27a30-ed72-4a25-ac82-fa0d16b08d40",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "9f9ecc39-7e11-4128-beaf-d1a24293afff"
      },
      "text": "complaintsnew\n| summarize count() by status\n| order by count_ desc",
      "id": "9bbbcec0-8603-4ca3-a899-2d03966708c3",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "9f9ecc39-7e11-4128-beaf-d1a24293afff"
      },
      "text": "complaintsnew\n| where satisfaction_score != \"\"\n| extend score = todouble(satisfaction_score)\n| join kind=inner (passengersnew | project passenger_id, frequent_flyer_tier) on passenger_id\n| summarize avg_score=round(avg(score), 2), complaints=count() by frequent_flyer_tier\n| order by avg_score asc\n",
      "id": "77b789ac-c380-469e-a4eb-e48c6440f2e6",
      "usedVariables": []
    }
  ]
